# Synology Critical Services Environment Template
# Copy values into the Synology stack environment or Portainer stack env section.
# Do not commit real secrets.

# Synology path roots
SYNOLOGY_DOCKER_ROOT=/volume1/docker
SYNOLOGY_CONFIG_ROOT=/volume1/docker/container_configs
SYNOLOGY_BACKUPS_ROOT=/volume1/backups

# PostgreSQL admin
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_PORT=5432

# Service databases
POSTGRES_GITEA_DB=gitea
POSTGRES_GITEA_USER=gitea
POSTGRES_GITEA_PASSWORD=your_secure_gitea_db_password_here

POSTGRES_N8N_DB=n8n
POSTGRES_N8N_USER=n8n
POSTGRES_N8N_PASSWORD=your_secure_n8n_db_password_here

# n8n
N8N_ENCRYPTION_KEY=your_32_char_random_encryption_key_here
N8N_HOST=n8n.your-domain-or-lan-host
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://n8n.your-domain-or-lan-host:5678/

# Gitea
GITEA_ROOT_URL=http://synology-nas:3002/
GITEA_SSH_DOMAIN=synology-nas
GITEA_SSH_PORT=2222

# Karakeep
NEXTAUTH_SECRET=your_random_secret_minimum_32_chars_here
MEILI_MASTER_KEY=your_random_meilisearch_master_key_here
OLLAMA_BASE_URL=http://host.docker.internal:11434
INFERENCE_TEXT_MODEL=gemma3
INFERENCE_IMAGE_MODEL=llava
INFERENCE_LANG=en
